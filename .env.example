# Conprospeccion OS2026 environment
# Copiar este archivo a .env en la raiz para desarrollo local.
# En Streamlit Cloud las variables van en Secrets. Nunca subir secretos reales.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GoHighLevel
GHL_AGENCY_TOKEN=
GHL_LOCATION_CONPROSPECCION=
GHL_TOKEN_CONPROSPECCION=
GHL_LOCATION_CLICKIE=
GHL_LOCATION_BAMBUTECH=
GHL_LOCATION_GBS=
GHL_TOKEN_CLICKIE=
GHL_TOKEN_BAMBUTECH=
GHL_TOKEN_GBS_LOGISTICS=

# Legacy/inactive client credentials retained only for old scripts while migrating.
GHL_LOCATION_TIRESIAS=
GHL_LOCATION_ECOSMART=
GHL_LOCATION_JUST4U=
GHL_TOKEN_TIRESIAS=
GHL_TOKEN_ECOSMART=
GHL_TOKEN_JUST4U=

# Prospecting data providers
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
APOLLO_API_KEY=

# Meeting evidence / Google Meet exports
# Put exported Google Meet transcript .txt/.md/.json files here, or edit docs/data/gbs-meeting-evidence.json.
GOOGLE_MEET_TRANSCRIPTS_DIR=docs/data/google-meet-transcripts
GOOGLE_MEET_EVIDENCE=docs/data/gbs-meeting-evidence.json
MANUAL_MEETINGS=docs/data/gbs-manual-meetings.json

# Internal tools / portals
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
ANTHROPIC_API_KEY=

# Alicia · respuestas de campañas Snov desde Telegram
# Interruptores de seguridad (por defecto: no envía nada, no usa IA).
ALICIA_ENABLED=false          # habilita el servicio/workflow completo
ALICIA_DRY_RUN=true           # true = no envía correos ni escribe en GHL de verdad
ALICIA_AI_ENABLED=false       # apaga TODA llamada a modelos de IA
# Horario y ventana (dos veces al día, configurable). El poller se auto-limita.
ALICIA_RUN_HOURS=8,20
ALICIA_TIMEZONE=America/Santiago
ALICIA_LOOKBACK_HOURS=14
# Modelo usado SOLO si se habilita la IA bajo petición (el más barato por defecto).
ALICIA_AI_MODEL=claude-haiku-4-5-20251001
# Gmail OAuth (una app OAuth; un refresh token por cuenta receptora).
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Registro de cuentas para el piloto (una sola). En producción usar la tabla
# public.alicia_accounts. token_env indica el NOMBRE del secreto, no su valor.
ALICIA_ACCOUNTS_JSON=[{"account_id":"cuenta01","email":"ventas@conprospeccion.com","enabled":true,"token_env":"GMAIL_REFRESH_TOKEN_CUENTA01","cliente_slug":"gbs"}]
GMAIL_REFRESH_TOKEN_CUENTA01=
# Validación del webhook entrante de Telegram (cabecera secreta).
TELEGRAM_WEBHOOK_SECRET=
MASTER_PASSWORD_FRANCISCA=
MASTER_PASSWORD_YANINA=
PORTAL_PASSWORD_CLICKIE=
PORTAL_PASSWORD_GBS=
PORTAL_PASSWORD_BAMBUTECH=
PORTAL_PASSWORD_TIRESIAS=
